{
  "manifest_version": 3,
  "name": "GitHub Team Visualizer",
  "version": "0.1.0",
  "description": "Adds manual GitHub group badges and public repo issue counts to issue and pull request discussions.",
  "permissions": ["storage"],
  "host_permissions": ["https://github.com/*", "https://api.github.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "css": ["content-styles.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/index.html"
}
